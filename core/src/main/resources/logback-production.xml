<configuration>
    <!-- =============================
         APPENDER: NORMAL LOGS (INFO/WARN)
         ============================= -->
    <appender name="NORMAL_LOGS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/usr/share/springboot/logs/app.log</file>

        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>DENY</onMatch>
            <onMismatch>ACCEPT</onMismatch>
        </filter>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rollover -->
            <fileNamePattern>/usr/share/springboot/logs/past.app.%d{yyyy-MM-dd}.log</fileNamePattern>

            <!-- keep 60 days' worth of history -->
            <maxHistory>90</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- =============================
         APPENDER: ERROR LOGS ONLY
         ============================= -->
    <appender name="ERROR_LOGS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/usr/share/springboot/logs/error.log</file>

        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/usr/share/springboot/logs/past.error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- =============================
         ROOT LOGGER
         ============================= -->
    <root level="info">
        <appender-ref ref="NORMAL_LOGS"/>
        <appender-ref ref="ERROR_LOGS"/>
    </root>
</configuration>